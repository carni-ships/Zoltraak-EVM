// =============================================================================
// C4.5: Lookup Table Access Functions
// =============================================================================

// Apply Keccak S-box to a byte using lookup table
inline uchar keccak_sbox(uchar x) {
    return KECCAK_SBOX[x];
}

// Apply inverse Keccak S-box
inline uchar keccak_sbox_inv(uchar x) {
    return KECCAK_SBOX_INV[x];
}

// Get opcode category
inline uchar get_opcode_category(uint opcode) {
    return OPCODE_CATEGORY_TABLE[opcode & 0xFF];
}

// Get base gas cost for opcode
inline uint get_base_gas(uint opcode) {
    uchar category = get_opcode_category(opcode);
    return GAS_BASE[category];
}

