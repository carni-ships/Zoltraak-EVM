// =============================================================================
// C4.9: Lookup Table Helper Functions
// =============================================================================

// Fast byte swap (for endianness conversion)
inline uchar byte_swap_8(uchar x) {
    return ((x & 0x80) >> 7) | ((x & 0x40) >> 5) | ((x & 0x20) >> 3) | ((x & 0x10) >> 1) |
           ((x & 0x08) << 1) | ((x & 0x04) << 3) | ((x & 0x02) << 5) | ((x & 0x01) << 7);
}

// Fast bit reversal for 8-bit value
inline uchar bit_reverse_8(uchar x) {
    return ((x & 0x01) << 7) | ((x & 0x02) << 5) | ((x & 0x04) << 3) | ((x & 0x08) << 1) |
           ((x & 0x10) >> 1) | ((x & 0x20) >> 3) | ((x & 0x40) >> 5) | ((x & 0x80) >> 7);
}

// Check if byte is ASCII digit (0-9)
inline bool is_digit(uchar x) {
    return x >= 0x30 && x <= 0x39;
}

// Check if byte is ASCII hex digit (0-9, A-F, a-f)
inline bool is_hex_digit(uchar x) {
    return is_digit(x) || (x >= 0x41 && x <= 0x46) || (x >= 0x61 && x <= 0x66);
}

// Hex digit to value
inline uchar hex_to_val(uchar x) {
    if (x >= 0x30 && x <= 0x39) return x - 0x30;
    if (x >= 0x41 && x <= 0x46) return x - 0x37;
    if (x >= 0x61 && x <= 0x66) return x - 0x57;
    return 0;
}

// =============================================================================
// C4.10: GPU Constant Memory Access Optimization
// =============================================================================
// These macros help optimize constant memory access patterns.

#define LUT_ACCESS(table, index) table[(index) & 0xFF]
#define LUT_ACCESS_16(table, index) table[(index) & 0x0F]
#define LUT_ACCESS_32(table, index) table[(index) & 0x1F]

